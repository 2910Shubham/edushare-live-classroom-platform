generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(STUDENT)
  isApproved    Boolean   @default(false)
  createdAt     DateTime  @default(now())

  taughtClasses Classroom[]      @relation("TeacherClasses")
  enrollments   Enrollment[]
  notes         StudentNote[]
  chatMessages  ChatMessage[]
  accounts      Account[]
  sessions      Session[]
  subscriptions PushSubscription[]
  analyticsSessions AnalyticsSession[]
  analyticsEvents   AnalyticsEvent[]
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

model Classroom {
  id          String    @id @default(cuid())
  name        String
  subject     String?
  code        String    @unique
  teacherId   String
  teacher     User      @relation("TeacherClasses", fields: [teacherId], references: [id])
  createdAt   DateTime  @default(now())

  enrollments  Enrollment[]
  materials    Material[]
  sessions     BoardSession[]
  chatMessages ChatMessage[]
}

model Enrollment {
  id          String    @id @default(cuid())
  userId      String
  classroomId String
  joinedAt    DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id])
  classroom   Classroom @relation(fields: [classroomId], references: [id])

  @@unique([userId, classroomId])
}

model Material {
  id           String       @id @default(cuid())
  classroomId  String
  uploadedById String
  title        String
  type         MaterialType
  fileUrl      String
  fileSize     Int?
  mimeType     String?
  pageCount    Int?
  createdAt    DateTime     @default(now())

  classroom    Classroom    @relation(fields: [classroomId], references: [id])
  annotations  Annotation[]
  notes        StudentNote[]
  chatMessages ChatMessage[]
}

enum MaterialType {
  IMAGE
  PDF
  PPT
  TEXT
}

model Annotation {
  id         String   @id @default(cuid())
  materialId String
  data       Json
  createdAt  DateTime @default(now())

  material   Material @relation(fields: [materialId], references: [id])
}

model StudentNote {
  id            String   @id @default(cuid())
  userId        String
  materialId    String
  content       String   @db.Text
  isAIGenerated Boolean  @default(false)
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id])
  material      Material @relation(fields: [materialId], references: [id])
}

model BoardSession {
  id          String    @id @default(cuid())
  classroomId String
  materialId  String?
  isLive      Boolean   @default(false)
  startedAt   DateTime  @default(now())
  endedAt     DateTime?

  classroom   Classroom @relation(fields: [classroomId], references: [id])
}

model ChatMessage {
  id          String    @id @default(cuid())
  classroomId String
  userId      String
  content     String    @db.Text
  materialId  String?
  type        String    @default("text") // text, doubt, material_share
  createdAt   DateTime  @default(now())

  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  material    Material? @relation(fields: [materialId], references: [id], onDelete: SetNull)

  @@index([classroomId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PushSubscription {
  id           String   @id @default(cuid())
  userId       String   @unique
  subscription String
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AnalyticsSession {
  id          String    @id @default(cuid())
  userId      String
  role        Role
  path        String
  classroomId String?
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  durationSec Int       @default(0)
  userAgent   String?

  user   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  events AnalyticsEvent[]

  @@index([userId])

  @@index([userId, startedAt])
  @@index([classroomId, startedAt])
  @@index([startedAt])
  @@index([endedAt])
}

model AnalyticsEvent {
  id          String   @id @default(cuid())
  sessionId   String?
  userId      String
  role        Role
  category    String
  action      String
  label       String?
  path        String?
  classroomId String?
  metadata    Json?
  createdAt   DateTime @default(now())

  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  session AnalyticsSession?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([category, createdAt])
  @@index([userId, createdAt])
  @@index([classroomId, createdAt])
  @@index([createdAt])
}
